ENVIRONMENT=development
APP_NAME=EngageAI API
LOG_LEVEL=INFO

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_KEY=change-me
API_RATE_LIMIT_PER_MINUTE=60
PIPELINE_TIMEOUT_SECONDS=120
PIPELINE_MAX_RETRIES=2
PIPELINE_MAX_EXECUTIONS_PER_DAY=5

LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
SESSION_JSON=
SESSION_MANAGER_SECRET=change-me-to-a-long-random-string

# Optional for now. The docker-compose setup uses the value below by default.
DATABASE_URL=postgresql+psycopg://engageai:engageai@postgres:5432/engageai

POSTGRES_DB=engageai
POSTGRES_USER=engageai
POSTGRES_PASSWORD=engageai
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
